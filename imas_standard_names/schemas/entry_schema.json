{
  "$defs": {
    "ArgumentRef": {
      "additionalProperties": false,
      "description": "Reference to another standard name as an argument of a structural operator.\n\nCaptures one layer of the ISN grammar's operator decomposition: the outer\noperator that wraps this entry around a *base* argument.  Entries emitted\nby the codex export pipeline carry ``arguments`` lists whose elements are\n``ArgumentRef`` instances.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "operator": {
          "title": "Operator",
          "type": "string"
        },
        "operator_kind": {
          "enum": [
            "unary_prefix",
            "unary_postfix",
            "binary",
            "projection"
          ],
          "title": "Operator Kind",
          "type": "string"
        },
        "role": {
          "anyOf": [
            {
              "enum": [
                "a",
                "b"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Role"
        },
        "separator": {
          "anyOf": [
            {
              "enum": [
                "and",
                "to"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Separator"
        },
        "axis": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Axis"
        },
        "shape": {
          "anyOf": [
            {
              "enum": [
                "component",
                "coordinate"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Shape"
        }
      },
      "required": [
        "name",
        "operator",
        "operator_kind"
      ],
      "title": "ArgumentRef",
      "type": "object"
    },
    "ExpressionProvenance": {
      "description": "Provenance describing an algebraic expression of existing names.\n\nFields\n------\nmode: Literal[\"expression\"] discriminator.\nexpression: Free-form (but catalog-governed) expression string.\ndependencies: List of standard name identifiers referenced by the\n    expression (used for dependency graph construction / validation).",
      "properties": {
        "mode": {
          "const": "expression",
          "default": "expression",
          "title": "Mode",
          "type": "string"
        },
        "expression": {
          "title": "Expression",
          "type": "string"
        },
        "dependencies": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Dependencies",
          "type": "array"
        }
      },
      "required": [
        "expression",
        "dependencies"
      ],
      "title": "ExpressionProvenance",
      "type": "object"
    },
    "OperatorProvenance": {
      "description": "Provenance describing a chain of operators applied to a base quantity.\n\nFields\n------\nmode: Literal[\"operator\"] discriminator.\noperators: Outermost-first sequence of primitive operator tokens, already\n    normalized (composite operators expanded) by the schema validator.\nbase: The underlying primitive standard name (scalar or vector) to which\n    the operators are applied.\noperator_id: Optional composite operator identifier (e.g. 'laplacian',\n    'second_time_derivative') if the user supplied one in the catalog. It\n    is not required and may be omitted if only primitive operators were\n    used. Validation does not derive this value; it simply preserves what\n    was provided for round-tripping / governance checks.",
      "properties": {
        "mode": {
          "const": "operator",
          "default": "operator",
          "title": "Mode",
          "type": "string"
        },
        "operators": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Operators",
          "type": "array"
        },
        "base": {
          "title": "Base",
          "type": "string"
        },
        "operator_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Operator Id"
        }
      },
      "required": [
        "operators",
        "base"
      ],
      "title": "OperatorProvenance",
      "type": "object"
    },
    "ReductionProvenance": {
      "description": "Provenance describing a standardized reduction / aggregation.\n\nFields\n------\nmode: Literal[\"reduction\"] discriminator.\nreduction: canonical reduction id (mean, rms, integral, magnitude, ...)\ndomain: contextual domain for the reduction (time, volume, flux_surface, none)\nbase: underlying standard name being reduced.",
      "properties": {
        "mode": {
          "const": "reduction",
          "default": "reduction",
          "title": "Mode",
          "type": "string"
        },
        "reduction": {
          "title": "Reduction",
          "type": "string"
        },
        "domain": {
          "default": "none",
          "title": "Domain",
          "type": "string"
        },
        "base": {
          "title": "Base",
          "type": "string"
        }
      },
      "required": [
        "reduction",
        "base"
      ],
      "title": "ReductionProvenance",
      "type": "object"
    },
    "StandardNameComplexEntry": {
      "additionalProperties": false,
      "description": "Complex-valued standard name catalog entry.\n\nUsed for quantities that have real and imaginary parts (or\nequivalently, magnitude and phase).  Examples include perturbed\nMHD quantities, wave amplitudes, and impedance components.",
      "properties": {
        "name": {
          "description": "Standard name token: snake_case (^[a-z][a-z0-9_]*$); starts with a letter; no double '__'.",
          "examples": [
            "electron_temperature",
            "gradient_of_electron_temperature",
            "radial_component_of_magnetic_field"
          ],
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Name",
          "type": "string"
        },
        "status": {
          "default": "draft",
          "description": "Lifecycle state: draft | active | deprecated | superseded.",
          "enum": [
            "draft",
            "active",
            "deprecated",
            "superseded"
          ],
          "title": "Status",
          "type": "string"
        },
        "deprecates": {
          "anyOf": [
            {
              "description": "Standard name token: snake_case (^[a-z][a-z0-9_]*$); starts with a letter; no double '__'.",
              "examples": [
                "electron_temperature",
                "gradient_of_electron_temperature",
                "radial_component_of_magnetic_field"
              ],
              "pattern": "^[a-z][a-z0-9_]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Deprecates"
        },
        "superseded_by": {
          "anyOf": [
            {
              "description": "Standard name token: snake_case (^[a-z][a-z0-9_]*$); starts with a letter; no double '__'.",
              "examples": [
                "electron_temperature",
                "gradient_of_electron_temperature",
                "radial_component_of_magnetic_field"
              ],
              "pattern": "^[a-z][a-z0-9_]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Superseded By"
        },
        "cocos_transformation_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cocos Transformation Type"
        },
        "description": {
          "description": "One concise sentence summarizing the physical quantity. Keep under 120 characters for readability. Should be self-contained and understandable without external context.",
          "maxLength": 180,
          "title": "Description",
          "type": "string"
        },
        "documentation": {
          "description": "Authoritative, self-contained documentation providing clear, comprehensive explanation of the physical quantity. This field must be fully standalone - a domain expert should understand the quantity completely without consulting external sources.",
          "title": "Documentation",
          "type": "string"
        },
        "validity_domain": {
          "default": "",
          "description": "Controlled vocabulary region of validity",
          "examples": [
            "core_plasma",
            "edge_plasma",
            "vacuum",
            "whole_plasma"
          ],
          "title": "Validity Domain",
          "type": "string"
        },
        "constraints": {
          "description": "Physical or mathematical constraints that must be satisfied (e.g. 'T_e > 0', 'kappa >= 1')",
          "examples": [
            [
              "T_e > 0"
            ],
            [
              "n_e >= 0",
              "n_e < 1e22 m^-3"
            ],
            [
              "kappa >= 1"
            ]
          ],
          "items": {
            "type": "string"
          },
          "title": "Constraints",
          "type": "array"
        },
        "tags": {
          "description": "Secondary classification tags from controlled vocabulary for cross-cutting classification.",
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        },
        "links": {
          "description": "Internal cross-references to related standard names only. Use format 'name:standard_name_token' (e.g., 'name:plasma_boundary'). Internal references are validated against the catalog.",
          "items": {
            "type": "string"
          },
          "title": "Links",
          "type": "array"
        },
        "arguments": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/ArgumentRef"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Arguments"
        },
        "error_variants": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "propertyNames": {
                "enum": [
                  "upper",
                  "lower",
                  "index"
                ]
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error Variants"
        },
        "kind": {
          "const": "complex",
          "default": "complex",
          "title": "Kind",
          "type": "string"
        },
        "unit": {
          "description": "Unit in fused dot-exponent style (auto-corrected to lexicographic token order). Tokens: alphanumerics only; join with '.'; exponents use ^ (e.g. m.s^-2). No '/', '*', or whitespace. Empty string for dimensionless.",
          "examples": [
            "eV",
            "m",
            "m.s^-1",
            "A.m^-2",
            "m^-3",
            "1"
          ],
          "pattern": "^[A-Za-z0-9]+(\\^[+-]?\\d+)?(\\.[A-Za-z0-9]+(\\^[+-]?\\d+)?)*$|^$",
          "title": "Unit",
          "type": "string"
        },
        "provenance": {
          "anyOf": [
            {
              "discriminator": {
                "mapping": {
                  "expression": "#/$defs/ExpressionProvenance",
                  "operator": "#/$defs/OperatorProvenance",
                  "reduction": "#/$defs/ReductionProvenance"
                },
                "propertyName": "mode"
              },
              "oneOf": [
                {
                  "$ref": "#/$defs/OperatorProvenance"
                },
                {
                  "$ref": "#/$defs/ExpressionProvenance"
                },
                {
                  "$ref": "#/$defs/ReductionProvenance"
                }
              ]
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provenance"
        }
      },
      "required": [
        "name",
        "description",
        "documentation",
        "unit"
      ],
      "title": "StandardNameComplexEntry",
      "type": "object"
    },
