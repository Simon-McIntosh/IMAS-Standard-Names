    "StandardNameTensorEntry": {
      "additionalProperties": false,
      "description": "Tensor (rank-2+) standard name catalog entry.\n\nUsed for quantities that represent tensor fields \u2014 metric tensors,\nstress tensors, conductivity tensors, etc.  Individual named\ncomponents (e.g. ``g11_covariant_metric_tensor_component``) are\nalso classified as *tensor* because they carry implicit index\nstructure.",
      "properties": {
        "name": {
          "description": "Standard name token: snake_case (^[a-z][a-z0-9_]*$); starts with a letter; no double '__'.",
          "examples": [
            "electron_temperature",
            "gradient_of_electron_temperature",
            "radial_component_of_magnetic_field"
          ],
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Name",
          "type": "string"
        },
        "status": {
          "default": "draft",
          "description": "Lifecycle state: draft | active | deprecated | superseded.",
          "enum": [
            "draft",
            "active",
            "deprecated",
            "superseded"
          ],
          "title": "Status",
          "type": "string"
        },
        "deprecates": {
          "anyOf": [
            {
              "description": "Standard name token: snake_case (^[a-z][a-z0-9_]*$); starts with a letter; no double '__'.",
              "examples": [
